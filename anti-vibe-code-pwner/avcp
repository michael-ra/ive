_llm_parse_response() {
  # Parse LLM JSON response, return: verdict|||summary|||adjustment|||confidence
  python3 -c "
import sys, json, re
text = sys.stdin.read()
match = re.search(r'\{[^{}]*\"verdict\"[^{}]*\}', text, re.DOTALL)
if match:
    try:
        data = json.loads(match.group())
        v = data.get('verdict', 'unknown')
        if v not in ('safe', 'suspicious', 'dangerous'): v = 'unknown'
        s = str(data.get('summary', ''))[:200]
