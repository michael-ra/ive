deep_scan_check_publish_frequency() {
  local pkg="$1" ecosystem="$2"
  [[ "$ecosystem" != "npm" ]] && return 0

  local rapid_publish
  rapid_publish=$(npm view "${pkg}" time --json 2>/dev/null | python3 -c "
import sys, json
from datetime import datetime, timezone

data = json.load(sys.stdin)
timestamps = []
for ver, ts in data.items():
    if ver in ('created', 'modified'): continue
    if any(c.isalpha() for c in ver.replace('.', '')): continue
    dt = datetime.fromisoformat(ts.replace('Z', '+00:00'))
    timestamps.append((ver, dt))

timestamps.sort(key=lambda x: x[1])

# Find versions published within 24h of each other
clusters = []
i = 0
while i < len(timestamps):
    cluster = [timestamps[i]]
    j = i + 1
    while j < len(timestamps) and (timestamps[j][1] - cluster[0][1]).total_seconds() < 86400:
        cluster.append(timestamps[j])
        j += 1
    if len(cluster) >= 2:
        window_start = cluster[0][1].strftime('%Y-%m-%d %H:%M')
        window_end = cluster[-1][1].strftime('%H:%M')
        hours = (cluster[-1][1] - cluster[0][1]).total_seconds() / 3600
        versions = ', '.join(c[0] for c in cluster)
        clusters.append(f'  {len(cluster)} versions in {hours:.0f}h: {versions} ({window_start}–{window_end} UTC)')
    i = j if j > i + 1 else i + 1

# Show most recent clusters (max 3)
for c in clusters[-3:]:
    print(c)
" 2>/dev/null)

  if [[ -n "$rapid_publish" ]]; then
    risk_add 5 "Multiple versions published within 24h"
    [[ "$JSON_DS_OUT" == false ]] && echo "$rapid_publish"
  else
    [[ "$JSON_DS_OUT" == false ]] && echo -e "  ${GREEN}OK${NC} No rapid-fire publishing detected"
  fi
}

deep_scan_diff_summary() {
  local old_dir="$1" new_dir="$2"
  local changed
  changed=$( { diff -rq "$old_dir" "$new_dir" || true; } 2>/dev/null | head -50)
  local n_changed n_added n_removed
  n_changed=$(echo "$changed" | grep -c "differ" || true)
  n_added=$(echo "$changed" | grep -c "Only in ${new_dir}" || true)
  n_removed=$(echo "$changed" | grep -c "Only in ${old_dir}" || true)

  echo "  Files changed: ${n_changed}, added: ${n_added}, removed: ${n_removed}"

  if [[ "$n_added" -gt 20 ]]; then
    risk_add 10 "Large number of new files (${n_added})"
  fi

  local diff_lines
  diff_lines=$( { diff -r "$old_dir" "$new_dir" || true; } 2>/dev/null | wc -l | tr -d '[:space:]')
  echo "  Total diff: ${diff_lines} lines"
  if [[ "$diff_lines" -gt 5000 ]]; then
    risk_add 5 "Large diff (${diff_lines} lines)"
  fi
}

