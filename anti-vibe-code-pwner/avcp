        echo -e "Pin to safe version: ${GREEN}${pkg}@${safe_version}${NC}" ;;
      suspicious)
        echo -e "${YELLOW}${BOLD}Proceed with caution.${NC} Review changes manually."
        echo -e "Safe fallback: ${GREEN}${pkg}@${safe_version}${NC}" ;;
      low-risk)
        echo -e "${CYAN}Minor flags.${NC} Likely safe, but review if concerned." ;;
      safe)
        echo -e "${GREEN}${BOLD}No suspicious indicators.${NC} Routine changes." ;;
    esac
    echo ""
    echo -e "${DIM}Tarballs saved at: ${DEEP_SCAN_TMP}${NC}"
    echo -e "${DIM}Manual inspect: diff -r ${DEEP_SCAN_TMP}/old/package ${DEEP_SCAN_TMP}/new/package${NC}"
  fi

  if [[ "$verdict" == "safe" ]]; then
    rm -rf "$DEEP_SCAN_TMP"
  fi

  case "$verdict" in
    dangerous) exit 2 ;;
    suspicious) exit 1 ;;
    *) exit 0 ;;
  esac
}

# ── Intercept: check a single shell command ──

# Package manager patterns that trigger a check
PKG_MGR_PATTERNS=(
  # pip / pip3
  '^pip3?\s+install'
  '^python3?\s+-m\s+pip\s+install'
  # npm
  '^npm\s+(install|i|add|update|upgrade|ci)\b'
  # yarn
  '^yarn\s+(add|install|upgrade|up)\b'
  # pnpm
  '^pnpm\s+(add|install|i|update|upgrade)\b'
  # bun
  '^bun\s+(add|install|i|update)\b'
  # cargo
  '^cargo\s+(add|install)\b'
  # go
  '^go\s+(get|install)\b'
  # gem / bundle
  '^gem\s+install\b'
  '^bundle\s+(install|add|update)\b'
  # composer
  '^composer\s+(require|install|update|upgrade)\b'
  # brew
  '^brew\s+(install|upgrade)\b'
)

is_package_manager_command() {
  local cmd="$1"
  # Strip leading whitespace, env vars, sudo, etc.
  local clean_cmd
  clean_cmd=$(echo "$cmd" | sed 's/^[[:space:]]*//' | sed 's/^sudo\s\+//' | sed 's/^[A-Z_]*=[^ ]*\s\+//')

  for pattern in "${PKG_MGR_PATTERNS[@]}"; do
    if echo "$clean_cmd" | grep -qE "$pattern"; then
      return 0
    fi
  done
  return 1
}

detect_ecosystem() {
  local cmd="$1"
  if echo "$cmd" | grep -qE '(^|\s)(pip3?|python)'; then
    echo "pypi"
  elif echo "$cmd" | grep -qE '(^|\s)(npm|yarn|pnpm|bun)\s'; then
    echo "npm"
  elif echo "$cmd" | grep -qE '(^|\s)cargo\s'; then
    echo "cargo"
  elif echo "$cmd" | grep -qE '(^|\s)go\s'; then
    echo "go"
  elif echo "$cmd" | grep -qE '(^|\s)(gem|bundle)\s'; then
    echo "rubygems"
  elif echo "$cmd" | grep -qE '(^|\s)composer\s'; then
    echo "packagist"
  elif echo "$cmd" | grep -qE '(^|\s)brew\s'; then
    echo "homebrew"
  else
    echo "unknown"
  fi
}

extract_packages_from_command() {
  local cmd="$1"
  local ecosystem="$2"

  # Strip the command prefix to get just the package arguments
  python3 -c "
import re, sys

cmd = '''${cmd}'''
ecosystem = '${ecosystem}'

# Normalize: strip sudo, env vars, leading whitespace
cmd = re.sub(r'^\\s*sudo\\s+', '', cmd)
cmd = re.sub(r'^[A-Z_]+=[^ ]+\\s+', '', cmd)

packages = []

if ecosystem == 'pypi':
    # pip install pkg1 pkg2 -r requirements.txt --upgrade pkg3
    # Extract -r file and named packages
    parts = cmd.split()
    skip_next = False
    has_r_flag = False
    for i, part in enumerate(parts):
        if skip_next:
            skip_next = False
            continue
        if part in ('-r', '--requirement'):
            has_r_flag = True
            skip_next = True
            continue
        if part.startswith('-'):
            if part in ('--upgrade', '-U', '--force-reinstall', '--no-deps', '-q', '--quiet'):
                continue
            skip_next = True  # skip flags with values
            continue
        if part in ('pip', 'pip3', 'install', 'python', 'python3', '-m'):
            continue
        # It's a package specifier
        pkg_name = re.split(r'[>=<\\[!~]', part)[0]
        if pkg_name and not pkg_name.startswith('.') and not pkg_name.startswith('/'):
            packages.append(pkg_name)
    if has_r_flag:
        packages.append('__manifest__')

elif ecosystem == 'npm':
    parts = cmd.split()
    subcmd = parts[1] if len(parts) > 1 else ''
    # npm install with no packages = manifest install
    named_pkgs = []
    skip_next = False
    for i, part in enumerate(parts[2:], start=2):
        if skip_next:
            skip_next = False
            continue
        if part.startswith('-'):
            if part in ('-D', '--save-dev', '-g', '--global', '-E', '--save-exact'):
                continue
            skip_next = True
            continue
        named_pkgs.append(re.split(r'@(?!.*@)', part)[0] if '@' in part and not part.startswith('@') else part.split('@')[0] if not part.startswith('@') else part.rsplit('@', 1)[0] if part.count('@') > 1 else part)
    if named_pkgs:
        packages = named_pkgs
    elif subcmd in ('install', 'i', 'ci'):
        packages.append('__manifest__')

elif ecosystem in ('cargo', 'go', 'rubygems', 'packagist', 'homebrew'):
    # Generic: extract non-flag args after the subcommand
    parts = cmd.split()
    skip_next = False
    for part in parts[2:]:  # skip 'cargo add', 'go get', etc.
        if skip_next:
            skip_next = False
            continue
        if part.startswith('-'):
            skip_next = True
            continue
        packages.append(part)

for p in packages:
    print(p)
" 2>/dev/null
}

cmd_intercept() {
  local command="$1"
  local threshold="${THRESHOLD_DAYS}"
  local verbose=false

  shift
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --threshold) threshold="$2"; shift 2 ;;
      --verbose) verbose=true; shift ;;
      *) shift ;;
    esac
  done

  # Fast exit: not a package manager command
  if ! is_package_manager_command "$command"; then
    echo '{"decision":"allow","reason":"not a package manager command"}'
    return 0
  fi

  local ecosystem
  ecosystem=$(detect_ecosystem "$command")

  local packages
  packages=$(extract_packages_from_command "$command" "$ecosystem")

  if [[ -z "$packages" ]]; then
    echo '{"decision":"allow","reason":"no packages detected in command"}'
    return 0
  fi

  # If it's a manifest install (__manifest__), we can't check individual packages here
  if echo "$packages" | grep -q '__manifest__'; then
    echo '{"decision":"warn","reason":"Manifest-based install detected. Run avcp scan for full check."}'
    return 0
  fi

  # Build package list for the Python scanner
  local pkg_args=()
  while IFS= read -r pkg; do
    [[ -z "$pkg" ]] && continue
    pkg_args+=("$pkg")
  done <<< "$packages"

  if [[ ${#pkg_args[@]} -eq 0 ]]; then
    echo '{"decision":"allow","reason":"no packages to check"}'
    return 0
  fi

  # Run unified scanner: recency + OSV vulns + GitHub advisories
  local scanner="$AVCP_DIR/lib/scanner.py"
  local results
  results=$(python3 "$scanner" check-multi "$ecosystem" "${pkg_args[@]}" --threshold "$threshold" 2>/dev/null) || {
    echo '{"decision":"allow","reason":"scanner error — allowing by default"}'
    return 0
  }

  # Check for install scripts (npm only)
  local scripts_warning=""
  if [[ "$ecosystem" == "npm" ]]; then
    local scripts_tmp
    scripts_tmp=$(mktemp /tmp/avcp-scripts.XXXXXX)
    for pkg in "${pkg_args[@]}"; do
      local pkg_scripts
      pkg_scripts=$(npm view "$pkg" scripts --json 2>/dev/null | python3 -c "
import sys, json
try:
    scripts = json.load(sys.stdin)
    hooks = []
    dangerous_patterns = ['curl', 'wget', 'node -e', 'sh -c', 'bash -c', 'eval', 'exec', 'child_process', 'base64', '/dev/tcp', 'nc ']
    for name in ('preinstall', 'install', 'postinstall'):
        if name in scripts:
            cmd = scripts[name]
            alerts = [p for p in dangerous_patterns if p.lower() in cmd.lower()]
            hooks.append({'name': name, 'command': cmd, 'alerts': alerts})
    if hooks:
        for h in hooks:
            alerts_str = ', '.join(h['alerts']) if h['alerts'] else 'none'
            print(f\"${pkg}|{h['name']}|{h['command']}|{alerts_str}\")
except:
    pass
" 2>/dev/null)
      if [[ -n "$pkg_scripts" ]]; then
        echo "$pkg_scripts" >> "$scripts_tmp"
      fi
    done

    if [[ -s "$scripts_tmp" ]]; then
      scripts_warning=$(python3 -c "
import sys
lines = open('${scripts_tmp}').read().strip().split('\n')
warnings = []
has_dangerous = False
for line in lines:
    if not line.strip():
        continue
    parts = line.split('|', 3)
    if len(parts) < 4:
        continue
    pkg, hook, cmd, alerts = parts
    if alerts != 'none':
        has_dangerous = True
        warnings.append(f'{pkg} has {hook} script containing [{alerts}]: {cmd[:80]}')
    else:
        warnings.append(f'{pkg} has {hook} script: {cmd[:80]}')
if warnings:
    print('\\n'.join(warnings))
" 2>/dev/null)
    fi
    rm -f "$scripts_tmp"
  fi

  # Process results
  python3 -c "
import json, sys

results = json.loads('''${results}''')
scripts_warning = '''${scripts_warning}'''
flagged = []
vulns = []
malware = []

for r in results:
    pkg = r.get('package', '')
    status = r.get('status', 'ok')
    ver = r.get('version', '')
    age = r.get('age_days', -1)
    fallback = r.get('fallback', '')

    if r.get('known_malware'):
        malware.append(f\"{pkg} v{ver}: {r.get('reason', 'KNOWN MALWARE')}\")
    elif status == 'flagged':
        detail = f\"{pkg} v{ver}\"
        reasons = []
        if age >= 0 and age < ${threshold}:
            reasons.append(f\"published {age}d ago\")
        if r.get('vuln_critical'):
            reasons.append(f\"{r.get('vuln_count', 0)} known vulnerabilities (CRITICAL/HIGH)\")
        elif r.get('vuln_count', 0) > 0:
            reasons.append(f\"{r['vuln_count']} known vulnerabilities\")
        if r.get('advisories'):
            for adv in r['advisories'][:2]:
                reasons.append(f\"advisory: {adv.get('summary', adv.get('ghsa_id', ''))}\")
        if fallback:
            reasons.append(f\"safe fallback: {fallback}\")
        detail += ' — ' + '; '.join(reasons) if reasons else ''
        flagged.append(detail)

    # Collect vuln info even for non-flagged
    for v in r.get('vulnerabilities', []):
        vulns.append(f\"{pkg}: {v.get('id', '')} — {v.get('summary', '')}\")

if malware:
    reason = 'AVCP BLOCKED — KNOWN MALWARE DETECTED: ' + '. '.join(malware)
    reason += '. DO NOT INSTALL.'
    print(json.dumps({'decision': 'block', 'reason': reason}))
elif flagged:
    reason = f'AVCP BLOCKED: {len(flagged)} package(s) flagged. '
    reason += '. '.join(flagged) + '. '
    reason += \"Run 'avcp scan --auto-fix' to pin safe versions, or set AVCP_THRESHOLD=0 to bypass.\"
    print(json.dumps({'decision': 'block', 'reason': reason}))
elif scripts_warning:
    # Packages passed recency/vuln checks but have install scripts
    reason = 'AVCP WARNING — install scripts detected. Review before proceeding:\\n' + scripts_warning
    reason += '\\n\\nTo install without scripts: npm install --ignore-scripts <pkg>'
    reason += '\\nTo approve and proceed: set AVCP_DISABLED=1 or re-run.'
    print(json.dumps({'decision': 'warn', 'reason': reason}))
elif vulns:
    context = f'AVCP: packages passed recency check but have {len(vulns)} known vulnerability(ies): '
    context += '; '.join(vulns[:3])
    print(json.dumps({'decision': 'warn', 'reason': context}))
else:
    ecosystem = '${ecosystem}'
    threshold = ${threshold}
    context = f'AVCP: all {ecosystem} packages verified safe (>{threshold}d old, no known vulns, no install scripts)'
    print(json.dumps({'decision': 'allow', 'reason': 'All packages passed security check', 'context': context}))
"
}

# ── Setup: install hooks ──

cmd_setup() {
  local target="${1:-}"
  [[ -z "$target" ]] && { echo "Usage: avcp setup <claude-code|gemini-cli|shell|all>"; exit 1; }

  case "$target" in
    claude-code) setup_claude_code ;;
    gemini-cli|gemini) setup_gemini_cli ;;
    shell) setup_shell ;;
    all)
      setup_claude_code
      echo ""
      setup_gemini_cli
      echo ""
      setup_shell
      ;;
    *) echo "Unknown target: $target (use: claude-code, gemini-cli, shell, all)"; exit 1 ;;
  esac
}

setup_claude_code() {
  echo -e "${BOLD}Setting up Claude Code hook...${NC}"

  local hook_script="$AVCP_DIR/hooks/claude-code.sh"
  chmod +x "$hook_script"

  # Determine settings file — prefer project-level if .claude/ exists, else global
  local settings_dir=""
  local settings_file=""
  local scope=""

  if [[ -d ".claude" ]]; then
    settings_dir=".claude"
    settings_file=".claude/settings.json"
    scope="project"
  else
    settings_dir="$HOME/.claude"
    settings_file="$HOME/.claude/settings.json"
    scope="global"
    mkdir -p "$settings_dir"
  fi

  # Read existing settings or create empty
  local existing="{}"
  if [[ -f "$settings_file" ]]; then
    existing=$(cat "$settings_file")
  fi

  # Merge the hook config
  python3 -c "
import json, sys

settings = json.loads('''${existing}''')

hook_entry = {
    'matcher': 'Bash',
    'hooks': [
        {
            'type': 'command',
            'command': '${hook_script}',
            'timeout': 30
        }
    ]
}

# Ensure hooks.PreToolUse exists
hooks = settings.setdefault('hooks', {})
pre_tool = hooks.setdefault('PreToolUse', [])

# Check if we already have an AVCP hook
avcp_exists = False
for entry in pre_tool:
    for h in entry.get('hooks', []):
        if 'avcp' in h.get('command', '').lower() or 'anti-vibe' in h.get('command', '').lower():
            h['command'] = '${hook_script}'
            avcp_exists = True

if not avcp_exists:
    pre_tool.append(hook_entry)

with open('${settings_file}', 'w') as f:
    json.dump(settings, f, indent=2)
    f.write('\n')

print('ok')
" 2>/dev/null

  echo -e "  ${GREEN}Done${NC} — hook installed in ${CYAN}${settings_file}${NC} (${scope})"
  echo -e "  Hook script: ${DIM}${hook_script}${NC}"
  echo -e "  Threshold:   ${DIM}AVCP_THRESHOLD env var (default: 7 days)${NC}"
  echo ""
  echo -e "  Claude Code will now check packages before every ${BOLD}pip install${NC},"
  echo -e "  ${BOLD}npm install${NC}, ${BOLD}yarn add${NC}, etc."
}

setup_gemini_cli() {
  echo -e "${BOLD}Setting up Gemini CLI hook...${NC}"

  local hook_script="$AVCP_DIR/hooks/gemini-cli.sh"
  chmod +x "$hook_script"

  local settings_dir=""
  local settings_file=""
  local scope=""

  if [[ -d ".gemini" ]]; then
    settings_dir=".gemini"
    settings_file=".gemini/settings.json"
    scope="project"
  else
    settings_dir="$HOME/.gemini"
    settings_file="$HOME/.gemini/settings.json"
    scope="global"
    mkdir -p "$settings_dir"
  fi

  local existing="{}"
  if [[ -f "$settings_file" ]]; then
    existing=$(cat "$settings_file")
  fi

  python3 -c "
import json

settings = json.loads('''${existing}''')

hook_entry = {
    'matcher': 'shell_execute|run_shell_command|Bash',
    'hooks': [
        {
            'name': 'avcp-supply-chain-check',
            'type': 'command',
            'command': '${hook_script}',
            'timeout': 30000
        }
    ]
}

hooks = settings.setdefault('hooks', {})
before_tool = hooks.setdefault('BeforeTool', [])

avcp_exists = False
for entry in before_tool:
    for h in entry.get('hooks', []):
        if 'avcp' in h.get('command', '').lower() or 'anti-vibe' in h.get('command', '').lower():
            h['command'] = '${hook_script}'
            avcp_exists = True

if not avcp_exists:
    before_tool.append(hook_entry)

with open('${settings_file}', 'w') as f:
    json.dump(settings, f, indent=2)
    f.write('\n')

print('ok')
" 2>/dev/null

  echo -e "  ${GREEN}Done${NC} — hook installed in ${CYAN}${settings_file}${NC} (${scope})"
  echo -e "  Hook script: ${DIM}${hook_script}${NC}"
  echo ""
  echo -e "  Gemini CLI will now check packages before every install command."
}

setup_shell() {
  echo -e "${BOLD}Setting up shell wrappers...${NC}"

  local wrapper="$AVCP_DIR/hooks/shell-wrapper.sh"
  local source_line="source \"${wrapper}\""
  local shell_rc=""

  # Detect shell
  if [[ -n "${ZSH_VERSION:-}" ]] || [[ "$SHELL" == *"zsh"* ]]; then
    shell_rc="$HOME/.zshrc"
  elif [[ -n "${BASH_VERSION:-}" ]] || [[ "$SHELL" == *"bash"* ]]; then
    shell_rc="$HOME/.bashrc"
  else
    shell_rc="$HOME/.profile"
  fi

  # Check if already installed
  if [[ -f "$shell_rc" ]] && grep -q "anti-vibe-code-pwner" "$shell_rc" 2>/dev/null; then
    # Update the existing line
    sed -i.bak "s|.*anti-vibe-code-pwner.*|${source_line}|" "$shell_rc"
    rm -f "${shell_rc}.bak"
    echo -e "  ${GREEN}Updated${NC} existing entry in ${CYAN}${shell_rc}${NC}"
  else
    echo "" >> "$shell_rc"
    echo "# Anti Vibe Code Pwner — supply chain security" >> "$shell_rc"
    echo "$source_line" >> "$shell_rc"
    echo -e "  ${GREEN}Added${NC} to ${CYAN}${shell_rc}${NC}"
  fi

  echo -e "  Wrapper: ${DIM}${wrapper}${NC}"
  echo ""
  echo -e "  Wrapped commands: pip, npm, yarn, pnpm, bun, cargo, go, gem,"
  echo -e "  bundle, composer, brew"
  echo ""
  echo -e "  Reload: ${CYAN}source ${shell_rc}${NC}"
  echo -e "  Bypass: ${CYAN}AVCP_DISABLED=1 npm install ...${NC}"
}

# ── Main ──

COMMAND="${1:-}"
[[ -z "$COMMAND" ]] && usage
shift

case "$COMMAND" in
  scan)
    while [[ $# -gt 0 ]]; do
      case $1 in
        --threshold) THRESHOLD_DAYS="$2"; shift 2 ;;
        --deep) DEEP_MODE=true; shift ;;
        --dry-run) DRY_RUN=true; shift ;;
        --auto-fix) AUTO_FIX=true; shift ;;
        --pip-only) CHECK_NPM=false; shift ;;
        --npm-only) CHECK_PIP=false; shift ;;
        --json) JSON_OUTPUT=true; shift ;;
        -h|--help) usage ;;
        -*)  echo "Unknown option: $1"; usage ;;
        *)   PROJECT_DIR="$1"; shift ;;
      esac
    done
    cmd_scan
    ;;
  intercept)
    [[ $# -lt 1 ]] && { echo '{"decision":"allow","reason":"no command provided"}'; exit 0; }
    cmd_intercept "$@"
    ;;
  setup)
    cmd_setup "$@"
    ;;
  scan-actions|actions)
    while [[ $# -gt 0 ]]; do
      case $1 in
        --threshold) THRESHOLD_DAYS="$2"; shift 2 ;;
        --json) JSON_OUTPUT=true; shift ;;
        -*) shift ;;
        *) PROJECT_DIR="$1"; shift ;;
      esac
    done
    cmd_scan_actions
    ;;
  scan-mcp|mcp)
    while [[ $# -gt 0 ]]; do
      case $1 in
        --json) JSON_OUTPUT=true; shift ;;
        -*) shift ;;
        *) PROJECT_DIR="$1"; shift ;;
      esac
    done
    cmd_scan_mcp
    ;;
  deep-scan|deepscan)
    cmd_deep_scan "$@"
    ;;
  ai)
    cmd_ai "$@"
    ;;
  version|-v|--version)
    echo "avcp v${VERSION}"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: $COMMAND"
    usage
    ;;
esac
