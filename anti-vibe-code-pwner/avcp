  mkdir -p "$dest_dir"
  (cd "$dest_dir" && npm pack "${pkg}@${version}" --pack-destination . >/dev/null 2>&1 && tar xzf *.tgz 2>/dev/null) || return 1
  echo "${dest_dir}/package"
}

deep_scan_download_pypi() {
  local pkg="$1" version="$2" dest_dir="$3"
  mkdir -p "$dest_dir"
  local download_url
  download_url=$(python3 -c "
import json, urllib.request
data = json.loads(urllib.request.urlopen('https://pypi.org/pypi/${pkg}/${version}/json').read())
for u in data.get('urls', []):
    if u['packagetype'] == 'sdist':
        print(u['url']); exit()
for u in data.get('urls', []):
    if u['packagetype'] == 'bdist_wheel':
        print(u['url']); exit()
" 2>/dev/null) || return 1
  [[ -z "$download_url" ]] && return 1
  local filename
  filename=$(basename "$download_url")
  curl -sf -o "${dest_dir}/${filename}" "$download_url" 2>/dev/null || return 1
  if [[ "$filename" == *.tar.gz || "$filename" == *.tgz ]]; then
    (cd "$dest_dir" && tar xzf "$filename" 2>/dev/null) || return 1
  elif [[ "$filename" == *.whl || "$filename" == *.zip ]]; then
    (cd "$dest_dir" && python3 -m zipfile -e "$filename" "extracted" 2>/dev/null) || return 1
