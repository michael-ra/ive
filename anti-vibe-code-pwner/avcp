  while [[ $# -gt 0 ]]; do
    case "$1" in
      --safe-version|--fallback) safe_version="$2"; shift 2 ;;
      --ecosystem) ecosystem="$2"; shift 2 ;;
      --threshold) THRESHOLD_DAYS="$2"; shift 2 ;;
      --json) JSON_DS_OUT=true; shift ;;
      -h|--help)
        echo "Usage: avcp deep-scan <package> [options]"
        echo "  --safe-version VER   Compare against this version (default: auto)"
        echo "  --ecosystem TYPE     npm or pypi (default: auto-detect)"
        echo "  --threshold N        Baseline age in days (default: 7)"
        echo "  --json               JSON output"
        exit 0 ;;
      -*) shift ;;
      *) pkg="$1"; shift ;;
    esac
  done

  [[ -z "$pkg" ]] && { echo "Usage: avcp deep-scan <package> [--safe-version VER]"; exit 1; }

  [[ "$JSON_DS_OUT" == false ]] && banner

