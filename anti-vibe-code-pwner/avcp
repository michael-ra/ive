    fi
  fi

  [[ "$JSON_DS_OUT" == false ]] && echo -e "Deep scanning: ${BOLD}${pkg}${NC} (${ecosystem})"
  [[ "$JSON_DS_OUT" == false ]] && echo ""

  # Get latest version
  local latest=""
  if [[ "$ecosystem" == "npm" ]]; then
    latest=$(npm view "$pkg" version 2>/dev/null)
  elif [[ "$ecosystem" == "pypi" ]]; then
    latest=$(python3 -c "
