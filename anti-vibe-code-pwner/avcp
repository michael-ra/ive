_run_actions_scan() {
  local scan_dir="$1"
  local actions_json
  actions_json=$(python3 "$AVCP_DIR/lib/scanner.py" scan-actions "$scan_dir" --threshold "$THRESHOLD_DAYS" 2>/dev/null)

  if [[ -z "$actions_json" ]]; then
    [[ "$JSON_OUTPUT" == false ]] && echo -e "  ${YELLOW}WARN${NC} Could not scan GitHub Actions"
    return 0
  fi

  local status
  status=$(echo "$actions_json" | python3 -c "import sys,json; print(json.load(sys.stdin).get('status','skip'))" 2>/dev/null)

  if [[ "$status" == "skip" ]]; then
    return 0
  fi

  # Display each action result and run LLM on flagged/warned ones
  local has_claude=false
  command -v claude &>/dev/null && has_claude=true

  # Write JSON to temp for line-by-line processing
  local actions_tmp
  actions_tmp=$(mktemp /tmp/avcp-actions.XXXXXX)
  echo "$actions_json" > "$actions_tmp"

  # Display results
  python3 -c "
import sys, json
data = json.load(open('${actions_tmp}'))
for a in data.get('actions', []):
    ref = a.get('action', '')
    status = a.get('status', 'ok')
    flags = a.get('flags', [])
    age = a.get('age_days', -1)

    if status == 'flagged':
        print(f'  \033[0;31mFLAG\033[0m \033[1m{ref}\033[0m')
        for f in flags:
            sev = f.get('severity', '')
            icon = '\033[0;31m!\033[0m' if sev == 'high' else '\033[1;33m~\033[0m'
            print(f'       {icon} {f[\"detail\"]}')
    elif status == 'warn':
        print(f'  \033[1;33mWARN\033[0m {ref}')
        for f in flags:
            print(f'       ~ {f[\"detail\"]}')
    else:
        age_str = f' — {age}d old' if age >= 0 else ''
        print(f'  \033[0;32mOK\033[0m   {ref}{age_str}')
" 2>/dev/null

  # Run LLM analysis on flagged/warned actions
  if [[ "$has_claude" == true ]]; then
    local action_refs
    action_refs=$(python3 -c "
import json
data = json.load(open('${actions_tmp}'))
for a in data.get('actions', []):
    if a.get('status') in ('flagged', 'warn'):
        print(a['action'] + '|||' + a['owner_repo'])
" 2>/dev/null)

    if [[ -n "$action_refs" ]]; then
      while IFS= read -r line; do
        local aref owner_repo ref_part
        aref=$(echo "$line" | python3 -c "import sys; print(sys.stdin.read().strip().split('|||')[0])" 2>/dev/null)
        owner_repo=$(echo "$line" | python3 -c "import sys; p=sys.stdin.read().strip().split('|||'); print(p[1] if len(p)>1 else '')" 2>/dev/null)
        ref_part=""
        if [[ "$aref" == *@* ]]; then
          ref_part="${aref##*@}"
        fi
        if [[ -n "$owner_repo" && -n "$ref_part" ]]; then
          _llm_analyze_action "$owner_repo" "$ref_part" "$aref"
        fi
      done <<< "$action_refs"
    fi
  fi

  rm -f "$actions_tmp"

  local flagged_count
  flagged_count=$(echo "$actions_json" | python3 -c "import sys,json; print(json.load(sys.stdin).get('flagged',0))" 2>/dev/null)
  if [[ "$flagged_count" -gt 0 ]]; then
    ISSUES_FOUND=$((ISSUES_FOUND + flagged_count))
    WARNINGS="${WARNINGS}\n  actions: ${flagged_count} GitHub Action(s) flagged"
  fi
}

