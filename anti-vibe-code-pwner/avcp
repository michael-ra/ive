        ["npm", "install", "--package-lock-only", "--ignore-scripts", "--no-audit", "--no-fund"],
        cwd=work_dir, capture_output=True, text=True, timeout=60
    )

    lock_path = os.path.join(work_dir, "package-lock.json")
    if not os.path.exists(lock_path):
        return {}

    with open(lock_path) as f:
        lock = json.load(f)

    # Parse lockfile v2/v3 format (packages key with node_modules/ prefixed paths)
    deps = {}
    for key, info in lock.get("packages", {}).items():
        if key == "":
            continue  # skip root
        # Extract package name from path like "node_modules/@scope/pkg" or "node_modules/a/node_modules/b"
        parts = key.split("node_modules/")
        name = parts[-1] if parts else key
        if not name:
            continue
        ver = info.get("version", "")
        if name and ver:
            deps[name] = ver
    return deps

print("STATUS|||resolving dependency trees...", file=sys.stderr)

# Resolve flagged version tree
flag_dir = tempfile.mkdtemp(prefix="avcp-tree-flag-")
try:
